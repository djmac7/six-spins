{
  "name": "six-spins-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Six Spins — single-session mobile-first React game (App spec v1).",
  "scripts": {
    "sync-data": "node scripts/sync-data.mjs",
    "make-placeholder": "node scripts/make-placeholder.mjs",
    "fetch-assets": "node scripts/fetch-assets.mjs",
    "predev": "npm run sync-data && npm run make-placeholder && npm run fetch-assets",
    "dev": "vite",
    "prebuild": "npm run sync-data && npm run make-placeholder && npm run fetch-assets",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "canvas-confetti": "^1.9.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
